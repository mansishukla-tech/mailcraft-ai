# Copy this file to ".env" in the server/ folder for local development.
# In AWS App Runner, set these as runtime environment variables/secrets instead
# of shipping a .env file inside the image.

# Required: your Anthropic API key (https://console.anthropic.com/)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional: override the Claude model used for generation
LLM_MODEL=claude-sonnet-4-5-20250929

# Server port (App Runner expects the container to listen on 8080 by default)
PORT=8080
NODE_ENV=development

# Origin allowed to call the API during local dev (Vite dev server)
CLIENT_ORIGIN=http://localhost:5173
